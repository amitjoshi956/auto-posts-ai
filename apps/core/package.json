{
  "name": "@autoposts/core",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build ./src/index.ts --compile --target=bun-linux-x64 --outfile=autoposts-core",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@autoposts/shared": "workspace:*",
    "@elysiajs/cors": "^1.4.1",
    "@sinclair/typebox": "^0.34.49",
    "elysia": "^1.4.28",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "bun-types": "^1.3.12",
    "typescript": "~6.0.3"
  }
}
